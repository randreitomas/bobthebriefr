# Server-side only — never prefix with VITE_

# IBM watsonx.ai (Granite)
WATSONX_API_KEY=your_ibm_cloud_api_key
WATSONX_PROJECT_ID=your_watsonx_project_id

# Optional overrides (defaults shown)
WATSONX_URL=https://jp-tok.ml.cloud.ibm.com
WATSONX_MODEL=ibm/granite-4-h-small

# Optional: comma-separated fallbacks if the primary model isn't in your region (Tokyo Lite often needs Llama)
# WATSONX_MODEL_FALLBACKS=ibm/granite-4-h-small,meta-llama/llama-3-3-70b-instruct
WATSONX_CHAT_VERSION=2024-10-08
